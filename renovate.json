{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly"
  ],
  "ignorePaths": [],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "groupName": "custom components",
      "labels": ["renovate"]
    },
    {
      "matchFileNames": ["docs/app/**"],
      "groupName": "docs app components"
    },
    {
      "matchManagers": ["github-actions"],
      "matchFileNames": [".github/**"],
      "groupName": "github actions"
    },
    {
      "matchManagers": ["github-actions"],
      "excludeFileNames": [".github/**"],
      "groupName": "recipes github actions"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile\\.tmpl$/"],
      "matchStrings": ["ARG GOMPLATE_VERSION=\"(?<currentValue>\\S+)\""],
      "depNameTemplate": "hairyhenderson/gomplate",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile\\.tmpl$/"],
      "matchStrings": ["ARG DIRENV_VERSION=\"(?<currentValue>\\S+)\""],
      "depNameTemplate": "direnv/direnv",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile\\.tmpl$/"],
      "matchStrings": ["ARG JQ_VERSION=\"(?<currentValue>\\S+)\""],
      "depNameTemplate": "jq",
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "jqlang/jq",
      "extractVersionTemplate": "^jq-(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile\\.tmpl$/"],
      "matchStrings": ["ARG YQ_VERSION=\"(?<currentValue>\\S+)\""],
      "depNameTemplate": "mikefarah/yq",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/Dockerfile\\.tmpl$/"],
      "matchStrings": ["ARG STARSHIP_VERSION=\"(?<currentValue>\\S+)\""],
      "depNameTemplate": "starship/starship",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile\\.tmpl$/"],
      "matchStrings": ["ARG FZF_VERSION=\"(?<currentValue>\\S+)\""],
      "depNameTemplate": "junegunn/fzf",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["_HADOLINT_VERSION = (?<currentValue>\\S+)"],
      "depNameTemplate": "hadolint/hadolint",
      "datasourceTemplate": "docker",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ]
}
